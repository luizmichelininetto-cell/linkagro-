# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Autenticação (deixe vazio para desabilitar em desenvolvimento)
API_KEY=troque-por-uma-chave-segura

# Banco de dados (SQLite por padrão, troque para PostgreSQL em produção)
DATABASE_URL=sqlite+aiosqlite:///./nf_scanner.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/nf_scanner

# Configurações gerais
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Upload
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,webp
